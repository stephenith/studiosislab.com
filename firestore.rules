rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{userId}/resume_docs/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{uid}/uploads/{assetId} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.storagePath is string
        && request.resource.data.downloadURL is string
        && request.resource.data.name is string
        && request.resource.data.size is int
        && request.resource.data.contentType.matches('image/.*')
        && request.resource.data.status == "ready";

      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.storagePath == resource.data.storagePath;

      allow delete: if isOwner(uid);
    }
  }
}
